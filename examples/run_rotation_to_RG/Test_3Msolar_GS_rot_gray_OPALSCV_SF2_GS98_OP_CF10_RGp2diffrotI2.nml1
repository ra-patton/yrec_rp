 $CONTROL  

 DESCRIP(1) = '3 solar mass model, diffusion, rotation'  
 DESCRIP(2) = 'Gray Atm OPAL06+SCV EOS GS98, differential rotation, after TAMS'

 LCALS = FALSE.  
 TOLL = 3.0D-5  
 TOLR = 3.0D-5  
 CALSOLAGE = 4.568D9
  
 NUMRUN = 1

 KINDRN(1) = 1  
 LFIRST(1) = .FALSE.  
 NMODLS(1) = 1200
 CMIXLA(1) = 1.822729

 

 LSTORE = .TRUE.       
 LSTATM = .FALSE.
 LSTENV = .FALSE.
 LSTMOD = .TRUE.
 LSTPHYS = .TRUE.
 LSTROT = .TRUE.
 NPRTMOD = 50              
 NPRTPT = 1 
 LSTPCH = .TRUE. 

 LTRACK = .TRUE.  
 ITRVER = 0  
  
 LRWSH = .FALSE.  
 LCORR = .TRUE.  
  
 LPULSE = .FALSE.  
  
 LALEX06 = .TRUE.  
 FALEX06 = "{YREC_INPUT}/opacity/molecular/alex06/alexmol06gs98.tab"  
   
 LOPAL95 = .TRUE.  
 ZOPAL951 = 0.017968  
 FLIV95 = "{YREC_INPUT}/opacity/atomic/legacy/opal95/GS98.OP17"  
  
 LPUREZ = .TRUE.  
 FPUREZ = "{YREC_INPUT}/opacity/atomic/lanl/PURECO.DBGLAOL"  
  
 FFIRST = "{YREC_START}/tams/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_TAMS.last"  ! Starting model path.
 FLAST = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.last" ! The last converged model is stored here.
 FMODPT = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.full" ! No longer used.
 FSTOR = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.store" ! Model snapshots during the run are stored here.
 FTRACK = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.track"! Global variables as a function of time are stored here.
 FSHORT = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.short" ! Details about the numerics of the model run are stored here. 
 FPMOD = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.pmod" ! Pulsation output for the interior model.
 FPENV = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.penv" ! Pulsation output for the envelope model.
 FPATM = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.atm" ! Pulsation output for the atmosphere model.
 FSNU = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.snu" ! No longer used (formally, output if LSNU = T).
 FSCOMP = "{YREC_OUTPUT}/Test_3Msolar_GS_rot_gray_OPALSCV_SF2_GS98_OP_CF10_RGp2diffrotI2.excomp" ! No longer used (light elements vs. time, now included in track file)
  
 FOPALE06 = "{YREC_INPUT}/eos/opal2006/EOSOPAL06Z0.016492" ! OPAL 2006 EoS table path.
 FcondOpacP = "{YREC_INPUT}/opacity/conductive/potekhin/condall06.d" ! Conductive opacity table path.
 FATM = "{YREC_INPUT}/atmos/kurucz/atmk1990p00.tab" ! Model atmosphere look-up table for Kurucz and Kurucz/Castelli.
 FALLARD = "{YREC_INPUT}/atmos/allard/Nextgen2.all" ! Allard model atmosphere look-up table (solar Z only).
 FSCVH = "{YREC_INPUT}/eos/scv/h_tab_i.dat" ! SCZ EoS table for X
 FSCVHE = "{YREC_INPUT}/eos/scv/he_tab_i.dat" ! SCZ EoS table for Y
 FSCVZ = "{YREC_INPUT}/eos/scv/z_tab_i.dat" ! SCZ EoS table for Z (generated from YREC EoS, needed for consistency)
 FFERMI = "{YREC_INPUT}/eos/yale/FERMI.TAB" ! Fermi integral tables for partial degeracy
  
 $END  
