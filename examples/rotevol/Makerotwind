
# The name for the executable can be changed after the NAME =

NAME = run_experiment


FFILES = \
rotwind.f	splinc.f	setup.f	ratext.f\
solidevol.f	int1zone.f	drevol.f	int2zone.f

# This part specifies the compiler options, and can be used to move 
# the executable to a target location by uncommenting the mv and 
# specifying a target for the move.

FFLAGS =  -c -O3 -w -ffixed-line-length-132

SRSFILES = $(FFILES)

OBJFILES = $(FFILES:.f=.o)

$(NAME):	$(OBJFILES)
	gfortran -g -o $(NAME) *.o 
#	mv $(NAME) target
.f.o:
	gfortran $(FFLAGS) -g -c $*.f -Wall -Wextra
